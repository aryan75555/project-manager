name: React Project Manager Frontend
services:
  - type: web
    name: frontend
    plan: starter
    buildCommand: npm run build
    startCommand: npm run preview
    runtime: node
    domains:
      - id: projecthub-app
        domain: projecthub.railway.app
    envs:
      - key: VITE_API_URL
        value: ${{ BACKEND_URL }}
    volumes:
      - name: node_modules
        path: /app/node_modules
